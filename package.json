{
  "name": "workerSmtp",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.4.2",
      "zod": "^4.4.3",
      "typescript": "^6",
      "@types/node": "^22.13.14",
      "@types/sanitize-html": "^2.16.1",
      "@cloudflare/workers-types": "^4.20260702.1",
      "hono": "^4.12.27",
      "@orpc/server": "^1.14.6",
      "@orpc/openapi": "^1.14.6",
      "@orpc/zod": "^1.14.6",
      "better-auth": "1.6.23",
      "alchemy": "^0.93.12",
      "lucide-react": "^1.23.0",
      "next-themes": "^0.4.6",
      "react": "^19.2.7",
      "react-dom": "^19.2.7",
      "sonner": "^2.0.7",
      "@orpc/client": "^1.14.6",
      "@types/react": "^19.2.17",
      "@types/react-dom": "^19.2.3",
      "sanitize-html": "^2.17.5",
      "tailwindcss": "^4.3.2"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "check-types": "turbo run check-types",
    "dev:web": "turbo run dev -F web",
    "dev:server": "turbo run dev -F server",
    "db:generate": "turbo run db:generate -F @workerSmtp/db",
    "deploy": "turbo run deploy -F @workerSmtp/infra",
    "destroy": "turbo run destroy -F @workerSmtp/infra",
    "check": "biome check --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "generate:secret": "echo \"BETTER_AUTH_SECRET=$(openssl rand -hex 32)\""
  },
  "dependencies": {
    "@workerSmtp/env": "workspace:*",
    "dotenv": "catalog:",
    "sanitize-html": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "@cloudflare/workers-types": "catalog:",
    "@playwright/test": "^1.61.1",
    "@types/node": "catalog:",
    "@types/sanitize-html": "catalog:",
    "@workerSmtp/config": "workspace:*",
    "turbo": "^2.10.2",
    "typescript": "catalog:",
    "vitest": "^4.1.10"
  },
  "packageManager": "bun@1.3.11"
}
